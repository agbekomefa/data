---
import BaseListing from "../../layouts/BaseListing.astro";
import { PAGES } from "../../config";

if (PAGES.consulting.isActive === false) {
    return Astro.redirect("/404");
}
---

<BaseListing
    title={PAGES.consulting.title}
    subtitle={PAGES.consulting.subtitle}
    description={PAGES.consulting.description}
    collection="consulting"
/>
